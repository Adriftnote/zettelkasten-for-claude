; height=&quot;40&quot; as=&quot;geometry&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;step4&quot; value=&quot;4️⃣ 모델이 응답 생성&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12&quot; parent=&quot;1&quot; vertex=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;730&quot; y=&quot;520&quot; width=&quot;150&quot; height=&quot;40&quot; as=&quot;geometry&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;step5&quot; value=&quot;5️⃣ Tool 호출 필요시 → 실행 → 결과 다시 전달&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12&quot; parent=&quot;1&quot; vertex=&quot;1&quot;&gt;&lt;mxGeometry x=&quot;910&quot; y=&quot;520&quot; width=&quot;250&quot; height=&quot;40&quot; as=&quot;geometry&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;flow-arrow1&quot; style=&quot;endArrow=classic;html=1;strokeWidth=1;strokeColor=#666666;&quot; parent=&quot;1&quot; source=&quot;step1&quot; target=&quot;step2&quot; edge=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;flow-arrow2&quot; style=&quot;endArrow=classic;html=1;strokeWidth=1;strokeColor=#666666;&quot; parent=&quot;1&quot; source=&quot;step2&quot; target=&quot;step3&quot; edge=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;flow-arrow3&quot; style=&quot;endArrow=classic;html=1;strokeWidth=1;strokeColor=#666666;&quot; parent=&quot;1&quot; source=&quot;step3&quot; target=&quot;step4&quot; edge=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=&quot;flow-arrow4&quot; style=&quot;endArrow=classic;html=1;strokeWidth=1;strokeColor=#666666;&quot; parent=&quot;1&quot; source=&quot;step4&quot; target=&quot;step5&quot; edge=&quot;1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;/&gt;&lt;/mxCell&gt;&lt;/root&gt;&lt;/mxGraphModel&gt;"><style type="text/css"></st