		{"id":"edge-5-6","fromNode":"step5","fromSide":"left","toNode":"step6","toSide":"right","label":"실행 완료"},
		{"id":"edge-6-7","fromNode":"step6","fromSide":"left","toNode":"step7","toSide":"right","label":"API 재호출"},
		{"id":"edge-7-1","fromNode":"step7","fromSide":"top","toNode":"step1","toSide":"bottom","label":"사용자에게 표시"},
		{"id":"edge-loop","fromNode":"step6","fromSide":"top","toNode":"step3","toSide":"bottom","label":"추가 Tool 필요시"}
	]
}