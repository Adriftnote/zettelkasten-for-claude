  "technical_details": {
    "training_configuration": {
      "base_model": "Qwen3-Reranker-0.6B",
      "optimizer": "AdamW",
      "learning_rate": "3×10^-5",
      "weight_decay": 0.01,
      "epochs": 3,
      "dropout": 0.4,
      "batch_size": {
        "global": 128,
        "per_device": 16,
        "gpus": 8
      },
      "fine_tuned_layers": "Last 2 transformer layers + feature fusion module",
      "attention": {
        "heads": 8,
        "hidden_size": 256
      }
    },
    "inference_configuration": {
      "threshold": 0.5,
      "max_interaction_rounds": 250,
      "temperature": 0,
      "seeds": 3
    },
    "algorithm": {
      "name": "Token Scoring and Line-level Aggregation",
      "steps": [
        "Compute token scores S = {s_1, s_2, ..., s_n} where s_i = f(x_i)",
        "For each line l_i: compute line score s̄_i = average of token scores",
        "Retain line if s̄_i > τ",
        "Use Viterbi decoding for structured coherent pruning"
      ]
    }
  },
