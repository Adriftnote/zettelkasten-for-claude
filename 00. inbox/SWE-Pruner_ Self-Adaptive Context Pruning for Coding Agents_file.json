  "abstract": {
    "problem": "LLM agents in software development face performance issues due to long interaction contexts, causing high API costs and latency. Existing compression methods ignore task-specific nature and disrupt code structure.",
    "solution": "SWE-Pruner - a self-adaptive context pruning framework mimicking human programmers' selective skimming behavior",
    "approach": "Agents formulate explicit goals to guide a lightweight neural skimmer (0.6B parameters) that dynamically selects relevant code lines",
    "results": {
      "agent_tasks": "23-54% token reduction on SWE-Bench Verified",
      "single_turn_tasks": "up to 14.84× compression on LongCodeQA",
      "performance_impact": "minimal"
    }
  },
  "key_contributions": [
    "Novel task-aware, line-level pruning framework for coding agents",
    "Lightweight architecture with only 0.6B parameters for efficient inference with adaptive pruning",
    "23-54% token reduction on agent tasks and up to 14.8× compression on single-turn tasks with minimal performance impact"
  ],
  "motivation": {
    "context_wall_problem": "LLM agents face accumulation of context length within constrained windows",
    "token_consumption_analysis": {
      "model": "Claude Sonnet 4.5",
      "benchmark": "SWE-Bench Verified",
      "read_operations": "76.1%",
      "execute_operations": "12.1%",
      "edit_operations": "11.8%",
      "validation_model": {
        "model": "GLM-4.6",
        "read_operations": "67.5%",
        "execute_operations": "18.5%",
        "edit_operations": "14.0%"
      }
    },
    "existing_limitations": [
      "Static compression ratios",
      "Task-agnostic criteria (e.g., perplexity)",
      "Inability to dynamically prioritize based on evolving goals",
      "Token pruning compromises syntactic validity",
      "Abstractive techniques discard character-level debugging information"
    ]
  },
  "methodology": {
    "overview": "SWE-Pruner operates as middleware between coding agents and environment, intercepting raw context and delivering pruned context",
    "components": [
      {
        "name": "Goal Hint Generation",
        "description": "Agents articulate explicit natural language goals (e.g., 'How is authentication handled?')",
        "implementation": "Augments file manipulation tools (cat, grep) with optional context_focus_question parameter",
        "benefits": "Minimal modifications to existing agent infrastructures"
      },
      {
        "name": "Lightweight Neural Skimmer",
        "architecture": {
          "backbone": "Qwen3-Reranker-0.6B",
          "parameters": "0.6B",
          "components": [
            "Multi-layer feature fusion (layers 7, 14, 28)",
            "CRF-based pruning head for line-level filtering",
            "Reranking head for document-level scoring"
          ]
        },
        "formulation": "Reranking problem computing relevance score for each token",
        "scoring_mechanism": {
          "token_level": "s_i = F(q, x_i | C; θ)",
          "line_level": "s̄_j = (1/|T_j|) Σ(s_t) for t in T_j",
          "threshold": "τ = 0.5"
        },
        "training_objective": {
          "primary": "CRF negative log-likelihood (CRF-NLL)",
          "secondary": "MSE for reranking head",
          "combined": "L_total = (1-λ)·L_compress + λ·L_rerank",
          "lambda": 0.05
        }
      },
      {
        "name": "Integration with Agentic Workflows",
        "multi_turn": "Agents dynamically generate Goal Hints at each round based on evolving reasoning trace",
        "single_turn": "Task description serves as initial Goal Hint, can be refined in subsequent retrieval rounds",
        "flexibility": "Seamless transition between broad exploration and focused investigation"
      }
    ],
    "training_data": {
      "source": "GitHub Code 2025 dataset",
      "method": "Teacher-student paradigm",
      "teacher_model": "Qwen3-Coder-30B-A3B-Instruct",
      "judge_model": "Qwen3-Next-80B-A3B-Thinking",
      "data_format": "Quadruplets (q, C, M, S) - query, context, binary line-level mask, document-level score",
      "total_samples": 61184,
      "query_statistics": {
        "average_words": 39.98,
        "median_words": 24.00,
        "average_characters": 291.69,
        "median_characters": 169.00
      },
      "task_taxonomy": [
        "Code Summarization",
        "Code Refactoring",
        "Relevant Part Identification",
        "Code Location",
        "Code Optimization",
        "Code Explanation",
        "Code Debugging",
        "Feature Addition",
        "Code Completion"
      ],
      "quality_control": "LLM-as-a-Judge filtering retaining approximately 1/6 of candidates"
    }
  },
